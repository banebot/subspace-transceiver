{
  "name": "agent-net",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/core && npm run build -w packages/daemon && npm run build -w packages/cli",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "lint": "tsc --noEmit --project tsconfig.base.json"
  },
  "devDependencies": {
    "@types/node": "22.13.9",
    "typescript": "5.8.2",
    "vitest": "4.0.18"
  }
}
