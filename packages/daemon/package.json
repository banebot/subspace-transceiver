{
  "name": "@subspace-net/daemon",
  "version": "0.1.0",
  "type": "module",
  "description": "Background daemon process for Subspace Transceiver — Fastify HTTP API + libp2p node",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "start:foreground": "node dist/index.js --foreground",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@subspace-net/core": "*",
    "fastify": "5.7.4",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@types/node": "22.13.9",
    "typescript": "5.8.2"
  }
}
