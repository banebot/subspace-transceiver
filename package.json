{
  "name": "subspace-transceiver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node patches/gossipsub-multiaddr-compat.js && node patches/gossipsub-stream-compat.js && node patches/gossipsub-handler-compat.js && node patches/orbitdb-sync-compat.js",
    "build": "npm run build -w packages/core && npm run build -w packages/daemon && npm run build -w packages/cli",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "test:e2e": "vitest run --config e2e/vitest.config.ts",
    "test:e2e:watch": "vitest --config e2e/vitest.config.ts",
    "test:e2e:perf": "vitest run --config e2e/vitest.config.ts --reporter=verbose e2e/perf.e2e.ts",
    "test:e2e:docker": "docker compose -f e2e/docker-compose.yml up --build --abort-on-container-exit --exit-code-from runner",
    "lint": "tsc --noEmit --project tsconfig.base.json",
    "build:binary": "bun run build:binary:macos-arm64 && bun run build:binary:macos-x64 && bun run build:binary:linux-x64",
    "build:binary:macos-arm64": "bun build --compile --target=bun-darwin-arm64 packages/cli/binary-entry.ts --outfile bin/subspace-macos-arm64",
    "build:binary:macos-x64": "bun build --compile --target=bun-darwin-x64 packages/cli/binary-entry.ts --outfile bin/subspace-macos-x64",
    "build:binary:linux-x64": "bun build --compile --target=bun-linux-x64 packages/cli/binary-entry.ts --outfile bin/subspace-linux-x64",
    "build:binary:windows-x64": "bun build --compile --target=bun-windows-x64 packages/cli/binary-entry.ts --outfile bin/subspace-windows-x64.exe"
  },
  "devDependencies": {
    "@types/node": "22.13.9",
    "typescript": "5.8.2",
    "vitest": "4.0.18"
  }
}
