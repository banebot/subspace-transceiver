{
  "name": "@subspace-net/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Core P2P networking and memory engine for Subspace Transceiver (Iroh + Loro CRDT)",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@libp2p/crypto": "5.1.13",
    "@libp2p/peer-id": "6.0.4",
    "loro-crdt": "1.10.6",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.13.9",
    "typescript": "5.8.2",
    "vitest": "4.0.18"
  }
}
