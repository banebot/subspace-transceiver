{
  "name": "@agent-net/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Core P2P networking and memory engine for agent-net (libp2p + OrbitDB)",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "14.1.2",
    "@chainsafe/libp2p-noise": "17.0.0",
    "@chainsafe/libp2p-yamux": "8.0.1",
    "@libp2p/autonat": "3.0.11",
    "@libp2p/bootstrap": "12.0.12",
    "@libp2p/circuit-relay-v2": "4.1.4",
    "@libp2p/crypto": "5.1.13",
    "@libp2p/dcutr": "3.0.11",
    "@libp2p/identify": "4.0.11",
    "@libp2p/kad-dht": "16.1.4",
    "@libp2p/mdns": "12.0.12",
    "@libp2p/peer-id": "6.0.4",
    "@libp2p/ping": "3.0.11",
    "@libp2p/pnet": "3.0.12",
    "@libp2p/tcp": "11.0.11",
    "@orbitdb/core": "3.0.2",
    "blockstore-level": "3.0.2",
    "datastore-level": "12.0.2",
    "helia": "6.0.20",
    "it-length-prefixed": "10.0.1",
    "it-pipe": "3.0.1",
    "libp2p": "3.1.4",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.13.9",
    "typescript": "5.8.2",
    "vitest": "4.0.18"
  }
}
